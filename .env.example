# Sanity配置
NEXT_PUBLIC_SANITY_PROJECT_ID=oquvb2bs
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token-here

# 网站配置
NEXT_PUBLIC_SITE_URL=https://www.elec-distributor.com

# 部署环境变量说明
# NEXT_PUBLIC_SANITY_PROJECT_ID: Sanity项目ID
# NEXT_PUBLIC_SANITY_DATASET: Sanity数据集名称
# SANITY_API_TOKEN: Sanity API令牌（在Sanity后台生成）
# NEXT_PUBLIC_SITE_URL: 网站域名